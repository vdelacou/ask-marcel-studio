{
  "name": "ask-marcel-studio",
  "version": "0.1.0",
  "description": "A radically simplified desktop AI studio: models, skills, and one agent-only conversation panel with Microsoft 365 always in reach.",
  "license": "MIT",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "lint": "eslint --cache --max-warnings=0",
    "lint:strict": "LINT_STRICT=1 eslint --max-warnings=0",
    "typecheck": "bun run typecheck:node && bun run typecheck:web",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "coverage": "bun run scripts/check-coverage.ts",
    "mutate": "stryker run",
    "mutate:changed": "bash scripts/mutate-changed.sh",
    "mutate:staged": "bash scripts/mutate-staged.sh",
    "fetch:python": "bun run scripts/fetch-python.ts",
    "fetch:wheels": "bun run scripts/fetch-wheels.ts",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3"
  },
  "trustedDependencies": ["better-sqlite3"],
  "dependencies": {
    "@ai-sdk/openai": "^4.0.15",
    "@ai-sdk/openai-compatible": "^3.0.14",
    "@anthropic-ai/claude-agent-sdk": "0.3.185",
    "@electron-toolkit/utils": "^4.0.0",
    "@milkdown/crepe": "^7.21.3",
    "@shikijs/langs": "^4.3.1",
    "@shikijs/rehype": "^4.3.1",
    "@shikijs/themes": "^4.3.1",
    "ai": "^7.0.30",
    "ask-marcel-office-cli": "^2.2.0",
    "better-sqlite3": "^13.0.1",
    "npm": "^12.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron/rebuild": "^4.2.0",
    "@eslint/js": "^10.0.1",
    "@stryker-mutator/core": "^9.6.1",
    "@tailwindcss/vite": "^4.3.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-sonarjs": "^4.2.0",
    "eslint-plugin-unicorn": "^72.0.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.3",
    "typescript": "^5",
    "typescript-eslint": "^8.64.0",
    "vite": "^7.3.6"
  }
}
