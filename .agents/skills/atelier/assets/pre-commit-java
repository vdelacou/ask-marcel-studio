#!/usr/bin/env bash
#
# atelier pre-commit hook (Java/Quarkus variant): the fast gates only
#
# A multi-minute hook trains `git commit --no-verify` (rule 15.1, and 15.3), so
# the hook carries only the fast gates. The slow, repo-scaling gates, `./mvnw
# verify` (compile, tests, JaCoCo tiers) and PIT mutation, run in CI, the line
# that cannot be skipped. See assets/ci-java.yml and references/java-quarkus.md.
#
#   1. commit size   : <=10 files AND <=300 lines (insertions + deletions)
#   2. pom sanity    : no version ranges, no -SNAPSHOT dependencies
#   3. secret scan   : gitleaks protect --staged (degrades gracefully)
#   4. format        : ./mvnw spotless:check
#
# Budget: keep the hook quick. spotless:check pays Maven startup; if that pushes
# the hook past the budget on your machine, move it to CI too. Never add `./mvnw
# verify` or PIT to this hook; they are CI-only by design.
#
# Install once per clone (alongside the shared commit-msg validator and CI):
#
#   cp <skill>/assets/pre-commit-java        .githooks/pre-commit
#   cp <skill>/assets/commit-msg             .githooks/commit-msg
#   cp <skill>/assets/ci-java.yml            .github/workflows/ci.yml
#   cp <skill>/assets/check-commit-size.sh   scripts/check-commit-size.sh
#   cp <skill>/assets/check-pom.sh           scripts/check-pom.sh
#   chmod +x .githooks/pre-commit .githooks/commit-msg scripts/*.sh
#   git config core.hooksPath .githooks
#
# Bypass with `git commit --no-verify` is reserved for genuine big-bang changes
# (initial scaffolds, mass-renames, generated-file updates). Justify every bypass
# in the commit body. Do not normalise bypassing.

set -euo pipefail

if [ ! -x ./mvnw ]; then
  echo "pre-commit: './mvnw' not found or not executable. Commit the Maven wrapper (rule 5, Java variant)." >&2
  exit 1
fi

echo "pre-commit: running the fast gates..."

echo "[1/4] commit size"
bash scripts/check-commit-size.sh

echo "[2/4] pom sanity (no ranges / -SNAPSHOT deps)"
bash scripts/check-pom.sh

echo "[3/4] gitleaks protect --staged"
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks protect --staged --redact --verbose --no-banner
else
  echo "  warning: 'gitleaks' not on PATH, skipping secret scan." >&2
  echo "  install: brew install gitleaks (or https://github.com/gitleaks/gitleaks/releases)" >&2
fi

echo "[4/4] ./mvnw spotless:check"
./mvnw -q spotless:check

echo "pre-commit: fast gates passed. ./mvnw verify and PIT run in CI (assets/ci-java.yml)."
