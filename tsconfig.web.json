{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": ["src/renderer/src/env.d.ts", "src/renderer/src/**/*", "src/renderer/src/**/*.tsx", "src/preload/*.d.ts", "src/shared/**/*"],
  "compilerOptions": {
    "composite": true,
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "noImplicitAny": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": { "@renderer/*": ["src/renderer/src/*"] }
  }
}
